# Credentials for the `deploy` command (keyless dev-image push). Copy to .env
# and fill in; .env is gitignored, so real values are never committed. direnv
# loads .env via .envrc (dotenv_if_exists .env).
#
# The operator issues you a Harbor robot scoped to push ONLY epochcloud/*-dev,
# plus a dev-user in your tenant Keycloak realm for the in-browser signing
# approval. No cosign key, no SOPS, no cluster access.

# Harbor host (the registry ingress).
EPOCHCLOUD_REGISTRY_HOST=registry.epoch.engineering

# Harbor robot scoped to push epochcloud/*-dev.
HARBOR_DEV_ROBOT_USER=
HARBOR_DEV_ROBOT_TOKEN=

# Optional overrides:
#   EPOCHCLOUD_IMAGE_NAME       Harbor image base name (no -dev). Defaults to the repo name.
#   EPOCHCLOUD_SIGNING_TENANT   Tenant realm slug for the keyless identity. Defaults to the git remote owner.
#   EPOCHCLOUD_CI_TOOLS_TAG     ci-tools-build image tag. Defaults to latest.
#   EPOCHCLOUD_PUSH_HOST        Registry push host. Defaults to registry-push.<domain>:5443.
